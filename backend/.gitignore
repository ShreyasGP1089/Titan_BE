# ============================================================================
# Backend .gitignore
# ============================================================================

# ============================================================================
# Environment & Secrets (CRITICAL)
# ============================================================================
.env
.env.local
*.key
*.pem

# Keep example files
!.env.example
!.env.production.example

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc

# ============================================================================
# Testing
# ============================================================================
test_*.py
*_test.py
.pytest_cache/
.coverage

# ============================================================================
# System Files
# ============================================================================
.DS_Store
._*

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# IDEs
# ============================================================================
.vscode/
.idea/
*.swp

# ============================================================================
# Documentation (Redundant - Keep only essential)
# ============================================================================
QUICKSTART.md
SETUP.md
SUCCESS_GUIDE.md
SWAGGER_GUIDE.md
SWAGGER_QUICKSTART.txt
VISUAL_GUIDE.md
CONNECTION_TROUBLESHOOTING.md
DEPLOYMENT.md
OPENAPI_CONFIG.json

# ============================================================================
# Scripts & Examples
# ============================================================================
generate_cert.sh
example_client.html

# ============================================================================
# Development Only Files
# ============================================================================
# MLX planner (Mac only, not for production)
mlx_planner.py

# Old API files (if using api_swagger.py)
api.py
main.py

# Development clients
qwen_client.py
planner.py

# ============================================================================
# KEEP THESE (Production Essential)
# ============================================================================
# api_swagger.py
# hf_planner.py
# search_pipeline.py
# db.py
# embedding.py
# tools.py
# config.py
# requirements_production.txt
