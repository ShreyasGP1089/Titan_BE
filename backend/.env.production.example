# Production Environment Configuration
# Copy to .env and update with your actual values

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=decathlon_db
POSTGRES_USER=decathlonuser
POSTGRES_PASSWORD=change_this_secure_password

# API Authentication
API_KEY=change_this_to_a_secure_random_key

# Model Configuration
HF_BASE_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
HF_ADAPTER_PATH=/app/training/outputs/qwen25_1_5b_lora_hf

# Hugging Face Cache (optional, improves startup time)
HF_HOME=/app/.cache/huggingface
TRANSFORMERS_CACHE=/app/.cache/transformers

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/api.log
