# ============================================================================
# Production Deployment .gitignore
# For Railway / Render / Cloud Deployment
# ============================================================================

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Backup files
*_backup.py
*_BACKUP.py
*_OLD_BACKUP.py
*_FIXED.py
*.backup
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
backend/.env
*.key
*.pem
*.p12
*.crt
*.cer

# Keep example files
!.env.example
!.env.production.example

# ============================================================================
# Operating System
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================================
# IDE & Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
.vim/

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================================================
# Testing
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Test files (not needed in production)
backend/test_*.py
backend/*_test.py

# Temporary test scripts created during debugging
backend/test_base_model.py

# ============================================================================
# Documentation (All Markdown Files)
# ============================================================================
# Ignore ALL .md files - documentation no longer maintained as markdown
*.md
backend/*.md
training/*.md

# ============================================================================
# Scripts (Development/Testing Only)
# ============================================================================
# Old/redundant scripts only - keep the new verification script

# Old verification scripts
verify_production_ready.sh
quick_verify.sh

# Development helper scripts
backend/generate_cert.sh
backend/example_client.html

# KEEP THESE:
# - verify_deployment_ready.sh (new, essential for pre-deployment checks)
# - deploy.sh (if exists)

# ============================================================================
# Training (not needed in production deployment)
# ============================================================================
# Keep only the production Qwen3 HF adapter, ignore everything else

# Training scripts
training/*.py
training/*.txt
training/*.json
!training/__init__.py
!training/train_hf.py
!training/requirements.txt

# Training data
training/data/
training/datasets/

# Legacy MLX / conversion outputs (backup only, not production)
training/outputs/shopping_agent_lora/
training/outputs/shopping_agent_lora_hf/
training/outputs/qwen25_3b_instruct_lora_hf/
training/outputs/qwen3_4b_lora/

# Keep only Qwen3 HF adapter for production
!training/outputs/qwen3_4b_hf/
!training/outputs/qwen3_4b_hf/*.safetensors
!training/outputs/qwen3_4b_hf/*.json

# ============================================================================
# Backend (Development Only)
# ============================================================================
# MLX planner (Mac only, not for Linux production)
backend/mlx_planner.py

# Old API files (if using api_swagger.py)
backend/api.py
backend/main.py

# Development clients
backend/qwen_client.py
backend/planner.py

# ============================================================================
# Model Cache (Large, download on deployment)
# ============================================================================
.cache/
*.bin
*.safetensors
models/
checkpoints/

# Hugging Face cache (too large, will download on server)
.cache/huggingface/
.cache/transformers/

# Keep only the production fine-tuned adapter
!training/outputs/qwen3_4b_hf/*.safetensors

# ============================================================================
# Docker (Local Development)
# ============================================================================
# Ignore local docker compose (keep for reference but not critical)
# docker-compose.yml is useful for local testing

# Docker volumes
postgres_data/
model_cache/

# ============================================================================
# Database
# ============================================================================
*.db
*.sqlite
*.sqlite3

# PostgreSQL backups
*.sql
*.dump

# ============================================================================
# Temporary Files
# ============================================================================
tmp/
temp/
*.tmp
*.temp
*.cache

# ============================================================================
# Git
# ============================================================================
.git/
.gitattributes

# ============================================================================
# ESSENTIAL FILES FOR DEPLOYMENT (DO NOT IGNORE)
# ============================================================================
# These files MUST be included:
#
# Root:
#   - Dockerfile                  (Container build)
#   - docker-compose.yml          (Local testing)
#   - README.md                   (Project overview)
#   - DEPLOY_NOW.md               (Deployment guide)
#   - DEPLOYMENT_ARCHITECTURE.md  (Architecture docs)
#
# Backend:
#   - api_swagger.py              (Main API)
#   - hf_planner.py               (Production planner)
#   - search_pipeline.py          (Search logic)
#   - db.py                       (Database)
#   - embedding.py                (Embeddings)
#   - tools.py                    (Helper functions)
#   - config.py                   (Configuration)
#   - requirements_production.txt (Dependencies)
#   - .env.example                (Env template)
#   - README.md                   (Backend docs)
#   - ARCHITECTURE.md             (Architecture)
#   - API_CONNECTION_GUIDE.md     (API usage)
#
# Training:
#   - outputs/qwen3_4b_hf/*.safetensors  (Qwen3 PEFT adapter)
#   - outputs/qwen3_4b_hf/*.json         (Adapter config)
#
# ============================================================================
